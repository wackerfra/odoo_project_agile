    </record>
    <record id="project_agile_demo_task_3" model="project.task">
        <field name="name">User profile page</field>
        <field name="project_id" ref="project_agile_demo_project"/>
        <field name="allocated_hours">20</field>
        <field name="sprint_id" ref="project_agile_demo_sprint_2"/>
    </record>
    <record id="project_agile_demo_task_4" model="project.task">
        <field name="name">Email notifications</field>
        <field name="project_id" ref="project_agile_demo_project"/>
        <field name="allocated_hours">12</field>
        <field name="sprint_id" ref="project_agile_demo_sprint_2"/>
