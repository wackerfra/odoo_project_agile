<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Demo Project -->
    <record id="project_agile_demo_project" model="project.project">
        <field name="name">Agile Demo Project</field>
    </record>

    <!-- Demo Sprints -->
    <record id="project_agile_demo_sprint_1" model="project.sprint">
        <field name="name">Sprint 1</field>
        <field name="project_id" ref="project_agile_demo_project"/>
        <field name="start_date">2026-01-01</field>
        <field name="end_date">2026-01-14</field>
        <field name="capacity_hours">160</field>
        <field name="state">closed</field>
    </record>

    <record id="project_agile_demo_sprint_2" model="project.sprint">
        <field name="name">Sprint 2</field>
        <field name="project_id" ref="project_agile_demo_project"/>
        <field name="start_date">2026-01-15</field>
        <field name="end_date">2026-01-28</field>
        <field name="capacity_hours">160</field>
        <field name="state">active</field>
    </record>

